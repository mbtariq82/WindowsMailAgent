<Window x:Class="Agent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agent.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#F3F6F9">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#E6EDF3"
                Padding="12">

            <DockPanel>

                <TextBlock Text="{Binding Header.EmailAddress}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#102027"
                           VerticalAlignment="Center"/>

                <TextBlock Text="{Binding Header.StatusText}"
                           Foreground="#4B5563"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"/>

            </DockPanel>
        </Border>

        <!-- AGENT CHAT -->
        <Border Grid.Row="1"
                Margin="10"
                Background="#F7FAFC"
                CornerRadius="8"
                Padding="8">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>   <!-- messages -->
                    <RowDefinition Height="Auto"/> <!-- input -->
                </Grid.RowDefinitions>

                <!-- Messages list -->
                <ListBox x:Name="ChatList"
                         Grid.Row="0"
                         ItemsSource="{Binding Conversation.Messages}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#102027"
                         Margin="4"
                         IsSynchronizedWithCurrentItem="True"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="4">
                                <TextBlock Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           Foreground="#102027"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Input area (switched from DockPanel to Grid) -->
                <Grid Grid.Row="1" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding Composer.CurrentMessage, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"
                             MinHeight="30"
                             AcceptsReturn="True"
                             HorizontalAlignment="Stretch"/>

                    <Button Grid.Column="1"
                            Content="Send"
                            Command="{Binding Composer.SendCommand}"
                            Width="80"
                            VerticalAlignment="Center"/>
                </Grid>
            </Grid>

        </Border>

    </Grid>
</Window>
