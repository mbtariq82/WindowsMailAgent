<Window x:Class="DesktopAgent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopAgent.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="PromptTextBox" Grid.Row="0" Margin="10" TextWrapping="Wrap" AcceptsReturn="True" Height="100"/>
        <Button x:Name="SendButton" Grid.Row="2" Content="Send" Margin="10" HorizontalAlignment="Right" Width="100" Click="SendButton_Click"/>
        <TextBlock x:Name="ResponseTextBlock" Grid.Row="1" Margin="10" TextWrapping="Wrap" VerticalAlignment="Top"/>
    </Grid>
</Window>
